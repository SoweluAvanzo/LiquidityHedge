# Dockerfile for LP Strategy Celery Workers
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Create data directory
RUN mkdir -p /data

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app

# Expose health check port
EXPOSE 8080

# Create a simple health check script
RUN echo '#!/bin/bash\ncelery -A tasks.celery_app inspect ping -d celery@$HOSTNAME 2>/dev/null | grep -q "pong" && echo "healthy" || exit 1' > /healthcheck.sh && chmod +x /healthcheck.sh

# Health check via celery inspect
HEALTHCHECK --interval=60s --timeout=30s --start-period=30s --retries=3 \
    CMD /healthcheck.sh

# Run Celery worker
# Concurrency is set via CELERY_CONCURRENCY env var (default 4)
CMD ["sh", "-c", "celery -A tasks.celery_app worker --loglevel=info --concurrency=${CELERY_CONCURRENCY:-4}"]
