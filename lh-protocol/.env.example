# Liquidity Hedge Protocol — Environment Configuration
#
# Copy to .env and fill in values:
#   cp .env.example .env

# ── Birdeye API (required for live-scenario-test) ──────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Solana RPC (required for live-orca-test) ───────────────
ANCHOR_PROVIDER_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# ── Wallets (required for live-orca-test) ──────────────────
# JSON keypair files (arrays of bytes)
WALLET_LP=./wallet-lp.json
WALLET_RT=./wallet-rt.json

# ── Orca Whirlpool (optional, defaults to mainnet SOL/USDC) ─
WHIRLPOOL_ADDRESS=Czfq3xZZDmsdGdUyrNLtRhGc47cXcZtLG4crryfu44zE

# ── Live test parameters (optional) ───────────────────────
TENOR_SECONDS=1200
# LP_SOL=0.01
# LP_USDC=2.0
# RT_USDC=20.0
